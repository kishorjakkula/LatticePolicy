{
  "name": "lattice-policy",
  "version": "0.1.0",
  "description": "Open-source framework for access-based insurance policy administration systems.",
  "private": true,
  "license": "Apache-2.0",
  "keywords": [
    "insurance",
    "policy-administration",
    "multi-tenant",
    "framework"
  ],
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "frontend",
    "server"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:server": "npm run build --workspace=server",
    "build": "npm run build:frontend && npm run build:server",
    "test:frontend": "npm run test --workspace=frontend",
    "test:server": "npm run test --workspace=server",
    "test:local": "npm run test:frontend && npm run test:server",
    "test": "sh scripts/test.sh",
    "test:docker": "sh scripts/test-docker.sh",
    "test:integration": "sh scripts/test-integration.sh",
    "test:e2e": "playwright test",
    "test:e2e:docker": "sh scripts/test-e2e-docker.sh",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.59.0",
    "@rollup/rollup-linux-arm64-musl": "^4.59.0"
  },
  "overrides": {
    "exceljs@4.4.0": {
      "uuid": "11.1.1"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
