# Copy this file to .env and fill in real values. Never commit .env.

# Database
DB_PASSWORD=yourStrongPassword
DB_USER=lattice_policy
DB_NAME=lattice_policy

# Server secrets
JWT_SECRET=change-me-please-use-a-long-random-string

# Optional: Sentry DSN for error tracking
SENTRY_DSN=
VITE_SENTRY_DSN=

# Optional: override API base URL (used by docker-compose build args)
VITE_API_BASE_URL=http://localhost:3300
